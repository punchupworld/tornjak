{
  "name": "tornjak",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "prepare": "husky",
    "dev": "bun run --watch src/index.ts",
    "lint": "oxlint . --fix",
    "format": "oxfmt . --write",
    "commitlint": "commitlint --edit .git/COMMIT_EDITMSG"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,ts,mts,cts,jsx,tsx}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "**/*.{json,jsonc,json5,yml,yaml,md,mdx,html,css,scss,less,toml}": "oxfmt --write"
  }
}
